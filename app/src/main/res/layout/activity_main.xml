<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".MainActivity"
        android:background="#252526">

    <Button
            android:text="SET INTEGER = 1"
            android:layout_width="279dp"
            android:layout_height="154dp"
            android:id="@+id/exhaustOpenButton"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="60dp"
            app:layout_constraintHorizontal_bias="0.048" />

    <Button
            android:text="SET INTEGER = 0"
            android:layout_width="279dp"
            android:layout_height="154dp"
            android:id="@+id/exhaustCloseButton"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="60dp"
            app:layout_constraintHorizontal_bias="0.924" />

    <TextView
            android:text="TextView"
            android:layout_width="804dp"
            android:layout_height="415dp"
            android:id="@+id/textView"
            app:layout_constraintStart_toStartOf="parent"
            app:autoSizeTextType="none"
            app:layout_constraintTop_toBottomOf="@+id/exhaustOpenButton"
            android:layout_marginTop="48dp"
            android:layout_marginStart="76dp"
            android:textColor="#D63333" />

</androidx.constraintlayout.widget.ConstraintLayout>